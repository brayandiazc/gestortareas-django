# ==============================================================================
# Variables de entorno — Gestor de Tareas (Django)
# ==============================================================================
# Copia este archivo a `.env` y completa los valores para tu entorno.
#   cp .env.example .env
#
# NUNCA subas tu archivo `.env` con valores reales al repositorio.
# Ver SECURITY.md y docs/conventions/secrets.md.
# ==============================================================================

# ── Django ────────────────────────────────────────────────────────────────
# Clave secreta para firmar sesiones/cookies. Genera una larga y aleatoria:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=
# Activa el modo debug: True en desarrollo, False en producción.
DEBUG=True
# Hosts permitidos, separados por comas (requerido cuando DEBUG=False).
# Ej: ALLOWED_HOSTS=localhost,127.0.0.1,midominio.com
ALLOWED_HOSTS=localhost,127.0.0.1

# ── Base de datos (PostgreSQL) ────────────────────────────────────────────
DB_ENGINE=django.db.backends.postgresql
DB_NAME=gestor_tareas_db
DB_USER=
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=5432
